{
  "name": "pi-web",
  "version": "0.1.0",
  "description": "Web-based UI for the pi coding agent",
  "type": "module",
  "bin": {
    "pi-web": "dist/cli.js"
  },
  "scripts": {
    "dev": "VITE_WS_URL=ws://localhost:3142 concurrently -k \"vite\" \"tsx src/cli.ts --port 3142 --no-open\"",
    "build": "tsc --project tsconfig.server.json && vite build",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
